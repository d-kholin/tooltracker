# Tool Tracker Environment Configuration
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# OIDC client credentials (from your identity provider, e.g. Authentik)
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# Full callback URL that your IdP will redirect to after login
OIDC_REDIRECT_URI=https://yourdomain.com/oidc/callback

# OIDC discovery endpoint (e.g. https://auth.yourdomain.com/application/o/tooltracker/.well-known/openid-configuration)
OIDC_DISCOVERY_URL=https://auth.yourdomain.com/application/o/tooltracker/.well-known/openid-configuration

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production; if omitted in development a random key is generated (sessions lost on restart)
SECRET_KEY=change-me-generate-a-real-secret

# ── Optional ──────────────────────────────────────────────────────────────────

# SQLite database path (default: tooltracker.db)
# TOOLTRACKER_DB=/data/tooltracker.db

# Upload folder for tool images (default: static/images)
# UPLOAD_FOLDER=/data/images

# Flask environment: development | production (default in docker-compose: production)
# FLASK_ENV=production

# Application display name (default: Tool Tracker)
# APP_NAME=Tool Tracker

# Base URL of the application (default: http://localhost:5000)
# APP_URL=https://yourdomain.com

# OIDC scopes (default: openid profile email)
# OIDC_SCOPES=openid profile email

# ── Manual OIDC endpoints (alternative to OIDC_DISCOVERY_URL) ─────────────────

# OIDC_AUTHORIZATION_ENDPOINT=https://auth.yourdomain.com/application/o/authorize/
# OIDC_TOKEN_ENDPOINT=https://auth.yourdomain.com/application/o/token/
# OIDC_USERINFO_ENDPOINT=https://auth.yourdomain.com/application/o/userinfo/
